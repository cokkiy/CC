{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CC-rClient",
  "version": "0.1.0",
  "identifier": "com.cokkiy.cc-rclient",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CC-rClient",
        "width": 1540,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}

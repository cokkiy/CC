/// Handle station list message
async fn handle_station_list(
    station_ids: &[String],
    stations: &Arc<RwLock<HashMap<String, Station>>>,
) -> Result<()> {
    debug!("Received station list with {} stations", station_ids.len());
    
    // Update station list
    let mut stations = stations.write().await;
    
    // Remove stations not in the list
    stations.retain(|id, _| station_ids.contains(id));
    
    // Add new stations
    for station_id in station_ids {
        if !stations.contains_key(station_id) {
            let station = Station {
                id: station_id.clone(),
                name: station_id.clone(),
                blocked: false,
                network_interfaces: Vec::new(),
                start_programs: Vec::new(),
                monitor_processes: Vec::new(),
                last_action: None,
            };
            
            stations.insert(station_id.clone(), station);
        }
    }
    
    Ok(())
}

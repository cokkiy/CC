                    } else if value.key.starts_with("network_tx_bytes_per_sec_") {
                        // Network TX rate
                    }
                }
            }
        }
    } else {
        // Create new station entry
        let station = Station {
            id: station_id.to_string(),
            name: station_id.to_string(),
            blocked: false,
            network_interfaces: Vec::new(),
            start_programs: Vec::new(),
            monitor_processes: Vec::new(),
            last_action: None,
        };
        
        stations.insert(station_id.to_string(), station);
    }
    
    Ok(())
}

